# ── NSE Simulator Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your API keys

# ── NewsAPI ───────────────────────────────────────────────────────────────────
# Get your free key at: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# ── Reddit API ────────────────────────────────────────────────────────────────
# Create an app at: https://www.reddit.com/prefs/apps
# Select "script" type, set redirect URI to http://localhost:8080
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=NSESimulator/1.0 by YourRedditUsername

# ── Optional: HuggingFace Token (needed only for gated models) ────────────────
# ProsusAI/finbert is public, so this is usually not required
# HUGGINGFACE_TOKEN=your_hf_token_here

# ── Cloud Database (optional — for cross-machine sync) ────────────────────────
# Without this, a local SQLite file is used (data stays on this machine only).
# To share data across machines (Mac + Windows), point both to the same cloud DB.
#
# Recommended: Supabase free tier (500 MB, no credit card needed)
#   1. Go to https://supabase.com → New project
#   2. Settings → Database → Connection string → URI  (copy it)
#   3. Paste below (replace the placeholder):
#
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres
#
# The ML model files (.joblib, .pt, optuna studies) always stay LOCAL — only the
# database (stocks, predictions, news, portfolio) is stored in the cloud.

# ── App settings (optional overrides) ─────────────────────────────────────────
# LOG_LEVEL=INFO
